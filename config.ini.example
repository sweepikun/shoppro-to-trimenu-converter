# ShopPro to TrMenu Converter 配置文件
# 将此文件复制到程序运行目录并重命名为 config.ini

# 输入输出目录 (可选)
# input = E:\aaa\plugins\ShopPro\shops
# output = E:\aaa\plugins\TrMenu\menus\商店

# 购买命令模板 (可选)
# 使用 {price}, {material}, {amount}, {player_name} 占位符
# buy_command = money take %player_name% {price} && give %player_name% {material} {amount}

# 出售命令模板 (可选)
# sell_command = take %player_name% {material} {amount} && money give %player_name% {price}

# 是否使用数据库存储每日限制 (默认true)
# use_database_limit = true

# 全文本替换 (可选)
# 格式: replace_原内容 = 替换内容
# 会对整个生成的YAML文件进行全文匹配替换
replace_{money} = %vault_eco_balance%
replace_%img_money% = %img_coin%
replace_$balance = %vault_eco_balance%
replace_money take = eco take
replace_money give = eco give
